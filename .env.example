# ============================================================
# Sanity
# ============================================================
# Create a project at https://www.sanity.io/manage and paste IDs.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-05-03

# Studio (only needed when running `npm run studio` standalone)
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production

# Read token (Viewer role) — required for SanityLive / draft mode.
NEXT_PUBLIC_SANITY_API_READ_TOKEN=

# Write token (Editor role) — for asset uploads from server actions (Phase 2).
SANITY_API_WRITE_TOKEN=

# Public preview origin (used by Presentation Tool)
NEXT_PUBLIC_PREVIEW_URL=http://localhost:3000

# ============================================================
# Neon Postgres
# ============================================================
# Pooled connection string from Neon dashboard.
DATABASE_URL=

# ============================================================
# Resend (magic-link emails) — Phase 2
# ============================================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@aeg.example
RESEND_FROM_NAME="AEG Contracting"

# ============================================================
# AI (Phase 3)
# ============================================================
ANTHROPIC_API_KEY=
